# --- Cliente (opcional): si se omite, se usa /api (recomendado con proxy) ---
VITE_API_BASE_URL=/api

# --- Solo servidor de Vite (dev / vite preview): NO usar prefijo VITE_ ---
# Backend al que el proxy reenvía /api
API_PROXY_TARGET=http://localhost:5021

# Mismo valor que Catalog:ApiKey en appsettings del API (nunca expuesto al bundle JS).
CATALOG_API_KEY=
